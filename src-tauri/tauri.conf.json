{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "LHM Monitor",
  "version": "3.1.0",
  "identifier": "com.lhm.monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LHM Monitor",
        "width": 420,
        "height": 660,
        "minWidth": 300,
        "minHeight": 200,
        "decorations": false,
        "resizable": true,
        "x": 1480,
        "y": 30
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
